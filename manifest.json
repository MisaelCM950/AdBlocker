{
  "manifest_version": 3,
  "name": "Ad Blocker",
  "version": "1.0",
  "description": "Blocks distracting ads and hides ad elements.",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "icons/logoadblocker.png",
    "48": "icons/logoadblocker.png",
    "128": "icons/logoadblocker.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ad Blocker"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*",
        "*://*.youtu.be/*",
        "*://*.gemini.google.com/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dummy.js", "dummy.json"],
      "matches": ["<all_urls>"]
    }
  ]
}