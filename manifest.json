{
  "manifest_version": 3,
  "name": "My Custom Ad Blocker",
  "version": "1.0",
  "description": "Blocks distracting ads and hides ad elements.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*",
        "*://*.youtu.be/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dummy.js", "dummy.json"],
      "matches": ["<all_urls>"]
    }
  ]
}