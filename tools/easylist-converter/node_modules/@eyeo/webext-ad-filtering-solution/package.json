{
  "name": "@eyeo/webext-ad-filtering-solution",
  "version": "4.1.0",
  "description": "eyeo's WebExtension Ad-Filtering Solution",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/eyeo/browser-extensions-and-premium/extensions/extensions"
  },
  "author": "eyeo GmbH",
  "license": "GPL-3.0",
  "type": "module",
  "main": "./dist/ewe-api.js",
  "types": "./src/types/index.d.ts",
  "exports": {
    ".": "./dist/ewe-api.js",
    "./background": "./dist/ewe-api.js",
    "./content": "./dist/ewe-content.js",
    "./content-main": "./dist/ewe-content-main.js",
    "./content-api": "./dist/ewe-content-api.js",
    "./ui": "./dist/ewe-ui.js",
    "./all/*": "./src/all/*",
    "./src/*": "./src/*",
    "./adblockpluscore/*": "./adblockpluscore/*",
    "./safari-polyfill-early": "./src/background/safari-polyfill-early.cjs"
  },
  "imports": {
    "#adblockpluscore/*": "./adblockpluscore/*"
  },
  "files": [
    "dist/*.js*",
    "adblockpluscore/data",
    "adblockpluscore/lib",
    "adblockpluscore/scripts",
    "adblockpluscore/package.json",
    "RELEASE_NOTES.md",
    "scripts",
    "sdk",
    "webpack.config.js",
    "src/types/*.d.ts",
    "src/background/safari-polyfill-early.cjs"
  ],
  "dependencies": {
    "@eyeo/remote-configuration-validator": "*",
    "@sentry/browser": "8.54.0",
    "json-rules-engine": "7.3.1",
    "jsonpath-plus": "10.3.0",
    "pako": "2.1.0",
    "semver": "7.7.2",
    "tar": "7.5.13",
    "uuid": "9.0.1",
    "yargs": "17.7.2"
  },
  "peerDependencies": {
    "mocha": "10.8.2",
    "webextension-polyfill": "*"
  },
  "devDependencies": {
    "@eyeo/get-browser-binary": "0.24.2",
    "@eyeo/snippets": "2.11.0",
    "@eyeo/test-utils": "*",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "5.2.7",
    "documentation": "14.0.3",
    "dotenv-webpack": "8.1.0",
    "expect": "25.5.0",
    "fake-indexeddb": "6.0.0",
    "geckodriver": "6.1.0",
    "generate-json-webpack-plugin": "2.0.0",
    "html-webpack-plugin": "5.6.3",
    "jsonschema": "1.5.0",
    "markdownlint": "0.28.2",
    "markdownlint-cli": "0.33.0",
    "mem-storage-area": "1.0.3",
    "mocha": "10.8.2",
    "nock": "13.5.6",
    "on-headers": "1.0.2",
    "selenium-webdriver": "4.23.0",
    "sinon": "11.1.2",
    "source-map-loader": "3.0.2",
    "terser-webpack-plugin": "5.5.0",
    "wbn": "0.0.8",
    "webpack": "5.97.1",
    "webpack-cli": "4.10.0"
  },
  "scripts": {
    "lint": "markdownlint --ignore-path ../../.gitignore .",
    "lint-fix": "npm run lint -- --fix",
    "docs": "documentation build --document-exported --sort-order alpha -f html -o public --config documentation.yml src/background/index.js src/background/filters.js src/background/subscriptions.js src/background/reporting.js src/background/cdp/index.js src/background/debugging.js src/background/telemetry/server-logger.js src/background/telemetry/index.js src/background/types.js src/background/experiments.js src/background/remote-config/index.js src/background/cohorts/engine.js src/background/account/index.js src/background/lightning-snippets.js",
    "docs-adblockpluscore": "jsdoc --configure adblockpluscore/.jsdoc.conf --destination public/adblockpluscore adblockpluscore/lib",
    "prepack": "npm run build:release",
    "build": "node scripts/build.js",
    "build:release": "npm run build -- --env release",
    "build:safari": "node scripts/safari/build.js",
    "build-then-test": "node scripts/build-and-test.js",
    "test": "npm run -w adblockpluscore test:unit && npm run test:unit && npm run test:scripts",
    "test:bundle": "node test/bundle/run.js",
    "test:functional": "node test/runners/functional.js",
    "test:performance": "node test/runners/performance.js",
    "test:scripts": "mocha test/scripts/*.js",
    "test:unit": "mocha --config ./test/unit/.mocharc.json ./test/unit/**/*.js",
    "subs-init": "node scripts/initSubscriptions.js",
    "subs-merge": "node scripts/mergeSubscriptions.js",
    "subs-fetch": "node scripts/fetchSubscriptions.js",
    "subs-convert": "node scripts/convertSubscriptions.js",
    "subs-generate": "node scripts/generateSubscriptionsFragment.js",
    "subs-run-mv3": "node scripts/prepare-mv3-files.js",
    "subs-run-mv2": "node scripts/prepare-mv2-files.js",
    "subs-clean": "node scripts/clean-mv3-files.js",
    "subs-run-performance-mv3": "node scripts/prepare-mv3-performance-files.js",
    "create-allowlisting-keypair": "node scripts/createKeypair.js"
  },
  "bin": {
    "subs-init": "./scripts/initSubscriptions.js",
    "subs-merge": "./scripts/mergeSubscriptions.js",
    "subs-fetch": "./scripts/fetchSubscriptions.js",
    "subs-convert": "./scripts/convertSubscriptions.js",
    "subs-generate": "./scripts/generateSubscriptionsFragment.js"
  },
  "nx": {
    "implicitDependencies": ["adblockpluscore"]
  }
}
